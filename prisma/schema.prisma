generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Member {
  id        Int      @id @default(autoincrement())
  memberId  String   @unique
  name      String
  email     String   @default("")
  phone     String   @default("")
  address   String   @default("")
  avatar    String   @default("")
  canSpend  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Transaction {
  id         Int      @id @default(autoincrement())
  txId       String   @unique
  timestamp  DateTime @default(now())
  memberName String
  income     Float    @default(0)
  expense    Float    @default(0)
  note       String   @default("")
  slipUrl    String   @default("")
  recordedBy String   @default("")
  createdAt  DateTime @default(now())
}

// Admin accounts allowed to log into the app.
model AdminUser {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  name         String   @default("")
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// App-wide configurable labels. Singleton row (id = 1).
model Setting {
  id            Int      @id @default(autoincrement())
  title         String   @default("เป๋าเรา Acc BA 34")
  subtitle      String   @default("")
  bankName      String   @default("กรุงเทพฯ (BBL)")
  accountNumber String   @default("123-4-56789-0")
  incomeTarget  Float    @default(500000)
  updatedAt     DateTime @updatedAt
}
